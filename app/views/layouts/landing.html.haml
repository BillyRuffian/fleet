!!!
%html
  %head
    %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title= @blog.title
    %meta{:content => "width=device-width,initial-scale=1", :name => "viewport"}/
    = csrf_meta_tags
    = csp_meta_tag
    = stylesheet_link_tag "application", "data-turbo-track": "reload"
    = stylesheet_link_tag "https://cdn.jsdelivr.net/gh/kimeiga/bahunya/dist/bahunya.min.css", 'data-turbo-track': 'reload'
    = javascript_importmap_tags
  %body
    %nav
      %a foo
      %a bar

    %header
      %h1= @blog.title
      - unless @blog.subtitle.blank?
        %big= @blog.subtitle

    = yield
    %footer
      %small Published with Fleet